rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return signedIn()
        && request.auth.token.email_verified == true
        && (!exists(/databases/$(database)/documents/users/$(request.auth.uid))
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('active', true) == true)
        && (request.auth.token.role == role
          || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role));
    }

    function validText(value, maxSize) {
      return value is string && value.size() > 0 && value.size() <= maxSize;
    }

    function validOptionalText(data, field, maxSize) {
      return !(field in data) || (data[field] is string && data[field].size() <= maxSize);
    }

    function validUserProfile(data) {
      return validText(data.email, 254)
        && validText(data.displayName, 80)
        && data.role in ['admin', 'counselor', 'student']
        && (!( 'active' in data) || data.active is bool)
        && (!('approvalStatus' in data)
          || data.approvalStatus in ['pending', 'approved', 'rejected']);
    }

    function validStudentRegistration(data) {
      return validText(data.uid, 128)
        && validText(data.email, 254)
        && validText(data.displayName, 80)
        && validText(data.studentNo, 40)
        && validText(data.department, 100)
        && validText(data.grade, 20)
        && validOptionalText(data, 'phone', 40)
        && validOptionalText(data, 'goal', 1000)
        && validOptionalText(data, 'concern', 5000)
        && data.get('interests', []) is list
        && data.get('interests', []).size() <= 20
        && data.emailVerified is bool
        && data.status in ['pending', 'approved', 'rejected']
        && data.counselorUid is string
        && data.counselorUid.size() <= 128;
    }

    function validStudent(data) {
      return validText(data.uid, 128)
        && validText(data.counselorUid, 128)
        && validText(data.name, 80)
        && validText(data.studentNo, 40)
        && validText(data.department, 100)
        && validText(data.grade, 20)
        && validOptionalText(data, 'phone', 40)
        && validOptionalText(data, 'goal', 1000)
        && validOptionalText(data, 'concern', 5000)
        && data.get('interests', []) is list
        && data.get('interests', []).size() <= 20
        && data.status in ['scheduled', 'inProgress', 'writing', 'complete'];
    }

    function validStudentSensitiveProfile(data) {
      return validText(data.studentId, 128)
        && validText(data.studentUid, 128)
        && validText(data.studentNo, 40)
        && validOptionalText(data, 'phone', 40);
    }

    function validOptionalAiReview(data) {
      return !('aiReview' in data)
        || (data.aiReview is map
          && data.aiReview.evidence is map
          && data.aiReview.evidence.summary is list
          && data.aiReview.evidence.summary.size() <= 5
          && data.aiReview.evidence.strengths is list
          && data.aiReview.evidence.strengths.size() <= 5
          && data.aiReview.evidence.concern is list
          && data.aiReview.evidence.concern.size() <= 5
          && data.aiReview.evidence.guidance is list
          && data.aiReview.evidence.guidance.size() <= 5
          && data.aiReview.needsConfirmation is list
          && data.aiReview.needsConfirmation.size() <= 10
          && data.aiReview.sensitiveWarning is list
          && data.aiReview.sensitiveWarning.size() <= 10
          && validText(data.aiReview.model, 100)
          && validText(data.aiReview.generatedAt, 40)
          && validText(data.aiReview.reviewedAt, 40)
          && validText(data.aiReview.reviewedBy, 80)
          && data.aiReview.reviewedFields is list
          && data.aiReview.reviewedFields.size() == 4
          && data.aiReview.evidenceCoverage is int
          && data.aiReview.evidenceCoverage >= 0
          && data.aiReview.evidenceCoverage <= 100
          && data.aiReview.confirmationAcknowledged is bool
          && data.aiReview.sensitiveAcknowledged is bool
          && data.aiReview.identifiersRedacted is bool);
    }

    function validOptionalProvenance(data) {
      return !('provenance' in data)
        || (data.provenance is map
          && data.provenance.type in ['ai-assisted', 'counselor-authored']
          && validText(data.provenance.reviewedAt, 40)
          && validText(data.provenance.reviewedBy, 80));
    }

    function validConsultation(data) {
      return validText(data.studentId, 128)
        && validText(data.studentUid, 128)
        && validText(data.counselorUid, 128)
        && validText(data.date, 10)
        && validText(data.type, 80)
        && validText(data.purpose, 500)
        && validText(data.summary, 5000)
        && data.studentVisible is bool
        && validOptionalText(data, 'guidance', 5000)
        && validOptionalText(data, 'strengths', 2000)
        && validOptionalText(data, 'concern', 5000)
        && validOptionalText(data, 'studentActions', 2000)
        && validOptionalText(data, 'counselorActions', 2000)
        && validOptionalText(data, 'nextCheckItems', 2000)
        && validOptionalAiReview(data);
    }

    function validConsultationSummary(data) {
      return validText(data.consultationId, 128)
        && validText(data.studentId, 128)
        && validText(data.studentUid, 128)
        && validText(data.counselorUid, 128)
        && validText(data.date, 10)
        && validText(data.type, 80)
        && validText(data.purpose, 500)
        && validOptionalText(data, 'summary', 5000)
        && validOptionalText(data, 'strengths', 2000)
        && validOptionalText(data, 'concern', 5000)
        && validOptionalText(data, 'studentActions', 2000)
        && validOptionalText(data, 'nextCheckItems', 2000)
        && data.get('programs', []) is list
        && data.get('visibleFields', []) is list
        && data.published is bool
        && validOptionalProvenance(data);
    }

    function validConsultationNote(data) {
      return validText(data.consultationId, 128)
        && validText(data.studentId, 128)
        && validText(data.counselorUid, 128)
        && validText(data.note, 10000);
    }

    function validConsultationDraft(data) {
      return validText(data.studentId, 128)
        && validText(data.counselorUid, 128)
        && validOptionalText(data, 'studentUid', 128)
        && validOptionalText(data, 'appointmentId', 128)
        && data.form is map
        && data.expiresAt is timestamp;
    }

    function validNotification(data) {
      return validText(data.recipientUid, 128)
        && validText(data.actorUid, 128)
        && validText(data.type, 40)
        && validText(data.title, 200)
        && validText(data.description, 1000)
        && validText(data.to, 300)
        && validOptionalText(data, 'readAt', 40);
    }

    function validFollowUp(data) {
      return validText(data.studentId, 128)
        && validText(data.ownerUid, 128)
        && validText(data.assigneeUid, 128)
        && validText(data.content, 500)
        && validText(data.dueDate, 10)
        && data.owner in ['학생', '교직원']
        && data.status in ['scheduled', 'inProgress', 'complete', 'overdue'];
    }

    function validAppointment(data) {
      return validText(data.studentId, 128)
        && validText(data.studentUid, 128)
        && validText(data.counselorUid, 128)
        && validText(data.date, 10)
        && validText(data.time, 5)
        && validOptionalText(data, 'endTime', 5)
        && validText(data.type, 80)
        && validText(data.location, 200)
        && validOptionalText(data, 'preparation', 1000)
        && validOptionalText(data, 'availabilityId', 128)
        && validOptionalText(data, 'subject', 200)
        && validOptionalText(data, 'requestMessage', 2000)
        && validOptionalText(data, 'preferredOutcome', 1000)
        && (!('requestedBy' in data) || data.requestedBy in ['student', 'counselor'])
        && (!('duration' in data) || (data.duration is int && data.duration >= 15 && data.duration <= 240))
        && data.status in ['pending', 'confirmed', 'scheduled', 'completed', 'cancelled'];
    }

    function validCounselorAvailability(data) {
      return validText(data.counselorUid, 128)
        && validText(data.date, 10)
        && validText(data.time, 5)
        && validOptionalText(data, 'endTime', 5)
        && validText(data.location, 200)
        && data.duration is int
        && data.duration >= 15
        && data.duration <= 240
        && data.status in ['open', 'booked', 'closed']
        && validOptionalText(data, 'appointmentId', 128)
        && validOptionalText(data, 'bookedByUid', 128);
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isCounselor() {
      return hasRole('counselor');
    }

    function isStudent() {
      return hasRole('student');
    }

    // Staff can manage operational resources such as programs. Identity,
    // approval, and student assignment changes remain administrator-only.
    function isStaff() {
      return isAdmin() || isCounselor();
    }

    function isAssignedStudent(studentId) {
      return signedIn()
        && exists(/databases/$(database)/documents/students/$(studentId))
        && get(/databases/$(database)/documents/students/$(studentId)).data.counselorUid
        == request.auth.uid;
    }

    function isDocumentCounselor(counselorUid) {
      return isCounselor() && counselorUid == request.auth.uid;
    }

    function hasMatchingStudentUid(studentId, studentUid) {
      return signedIn()
        && studentUid is string
        && studentUid.size() > 0
        && exists(/databases/$(database)/documents/students/$(studentId))
        && get(/databases/$(database)/documents/students/$(studentId)).data.uid
        == studentUid;
    }

    function isValidStudentCompletion() {
      return resource.data.status != 'complete'
        && request.resource.data.status == 'complete'
        && request.resource.data.completedAt is string
        && request.resource.data.completedAt.matches(
          '^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}[.][0-9]{3}Z$'
        )
        && request.resource.data.updatedAt is string
        && request.resource.data.updatedAt.matches(
          '^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}[.][0-9]{3}Z$'
        )
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'completedAt', 'updatedAt']);
    }

    match /users/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow create: if validUserProfile(request.resource.data) && (isAdmin()
        || (signedIn()
          && request.auth.uid == userId
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.role in ['student', 'counselor']
          && request.resource.data.active == false
          && request.resource.data.approvalStatus == 'pending'));
      allow update: if validUserProfile(request.resource.data) && (isAdmin()
        || (signedIn()
          && request.auth.uid == userId
          && resource.data.role == 'student'
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == resource.data.email
          && request.resource.data.displayName == resource.data.displayName
          && resource.data.active == true
          && request.resource.data.active == false
          && request.resource.data.withdrawalStatus == 'pending'
          && request.resource.data.withdrawalRequestedAt is string
          && request.resource.data.deletionScheduledAt is string
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['active', 'withdrawalStatus', 'withdrawalRequestedAt', 'deletionScheduledAt', 'updatedAt'])));
      allow delete: if isAdmin();
    }

    match /studentRegistrations/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow create: if signedIn()
        && request.auth.uid == userId
        && validStudentRegistration(request.resource.data)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.emailVerified == false
        && request.resource.data.status == 'pending'
        && request.resource.data.counselorUid == '';
      allow update: if validStudentRegistration(request.resource.data) && (
        isAdmin()
        || (signedIn()
          && request.auth.uid == userId
          && request.auth.token.email_verified == true
          && resource.data.status == 'pending'
          && request.resource.data.status == 'pending'
          && request.resource.data.counselorUid == ''
          && request.resource.data.emailVerified == true
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['emailVerified', 'updatedAt'])));
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isAdmin()
        || (isCounselor() && resource.data.counselorUid == request.auth.uid)
        || (isStudent() && resource.data.uid == request.auth.uid);
      // Student identity and assignment changes remain administrator-only.
      // Assigned counselors can update the students in their own caseload.
      allow create: if isAdmin() && validStudent(request.resource.data);
      allow update: if validStudent(request.resource.data) && (isAdmin()
        || (isCounselor()
          && resource.data.counselorUid == request.auth.uid
          && request.resource.data.counselorUid == resource.data.counselorUid
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['interests', 'goal', 'concern', 'status', 'appointmentDate',
              'appointment', 'lastConsultation', 'updatedAt']))
        || (isStudent()
          && resource.data.uid == request.auth.uid
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.counselorUid == resource.data.counselorUid
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['interests', 'goal', 'concern', 'updatedAt'])));
      allow delete: if isAdmin();
    }

    // Full student identifiers are never readable from the client. They are
    // returned only by the callable function after assignment + PIN checks.
    match /studentSensitiveProfiles/{studentId} {
      allow read: if false;
      allow create, update: if isAdmin()
        && validStudentSensitiveProfile(request.resource.data)
        && request.resource.data.studentId == studentId;
      allow delete: if isAdmin();
    }

    // PIN hashes, throttling state, and reveal audit records are Admin SDK only.
    match /sensitiveAccessCredentials/{userId} {
      allow read, write: if false;
    }

    match /sensitiveAccessAttempts/{userId} {
      allow read, write: if false;
    }

    match /sensitiveAccessAudit/{auditId} {
      allow read, write: if false;
    }

    match /consultations/{consultationId} {
      allow read: if isAdmin()
        || isDocumentCounselor(resource.data.counselorUid);
      allow create: if validConsultation(request.resource.data) && (isAdmin()
        || (isCounselor()
          && request.resource.data.counselorUid == request.auth.uid
          && isAssignedStudent(request.resource.data.studentId)
          && hasMatchingStudentUid(
            request.resource.data.studentId,
            request.resource.data.studentUid
          )));
      allow update: if validConsultation(request.resource.data) && (isAdmin()
        || (isCounselor()
          && resource.data.counselorUid == request.auth.uid
          && request.resource.data.counselorUid == resource.data.counselorUid
          && request.resource.data.studentUid == resource.data.studentUid
          && request.resource.data.studentId == resource.data.studentId));
      allow delete: if isAdmin()
        || (isDocumentCounselor(resource.data.counselorUid)
          && isAssignedStudent(resource.data.studentId));
    }

    match /consultationSummaries/{summaryId} {
      allow read: if isAdmin()
        || isDocumentCounselor(resource.data.counselorUid)
        || (isStudent()
          && resource.data.studentUid == request.auth.uid
          && resource.data.published == true);
      allow create: if validConsultationSummary(request.resource.data)
        && (isAdmin()
          || (isDocumentCounselor(request.resource.data.counselorUid)
            && isAssignedStudent(request.resource.data.studentId)));
      allow update: if validConsultationSummary(request.resource.data)
        && (isAdmin()
          || (isDocumentCounselor(resource.data.counselorUid)
            && isAssignedStudent(resource.data.studentId)
            && request.resource.data.counselorUid == resource.data.counselorUid
            && request.resource.data.studentId == resource.data.studentId
            && request.resource.data.studentUid == resource.data.studentUid));
      allow delete: if isAdmin()
        || (isDocumentCounselor(resource.data.counselorUid)
          && isAssignedStudent(resource.data.studentId));
    }

    match /consultationNotes/{noteId} {
      allow read: if isAdmin()
        || isDocumentCounselor(resource.data.counselorUid);
      allow create: if validConsultationNote(request.resource.data) && (isAdmin()
        || (isCounselor()
          && request.resource.data.counselorUid == request.auth.uid
          && isAssignedStudent(request.resource.data.studentId)));
      allow update: if validConsultationNote(request.resource.data) && (isAdmin()
        || (isCounselor()
          && resource.data.counselorUid == request.auth.uid
          && request.resource.data.counselorUid == resource.data.counselorUid
          && request.resource.data.studentId == resource.data.studentId));
      allow delete: if isAdmin()
        || (isDocumentCounselor(resource.data.counselorUid)
          && isAssignedStudent(resource.data.studentId));
    }

    match /consultationDrafts/{draftId} {
      allow read: if isCounselor() && resource.data.counselorUid == request.auth.uid;
      allow create: if isCounselor() && validConsultationDraft(request.resource.data)
        && request.resource.data.counselorUid == request.auth.uid;
      allow update: if isCounselor() && validConsultationDraft(request.resource.data)
        && resource.data.counselorUid == request.auth.uid
        && request.resource.data.counselorUid == resource.data.counselorUid;
      allow delete: if isCounselor() && resource.data.counselorUid == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.recipientUid == request.auth.uid;
      allow create: if signedIn() && validNotification(request.resource.data)
        && request.resource.data.actorUid == request.auth.uid;
      allow update: if signedIn() && resource.data.recipientUid == request.auth.uid
        && validNotification(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
      allow delete: if false;
    }

    match /followUps/{followUpId} {
      allow read: if isAdmin()
        || (isCounselor()
          && resource.data.ownerUid == request.auth.uid)
        || (isStudent() && resource.data.assigneeUid == request.auth.uid);
      allow create: if validFollowUp(request.resource.data) && (isAdmin()
        || (isCounselor()
          && request.resource.data.ownerUid == request.auth.uid
          && isAssignedStudent(request.resource.data.studentId)
          && (request.resource.data.assigneeUid == request.auth.uid
            || hasMatchingStudentUid(
              request.resource.data.studentId,
              request.resource.data.assigneeUid
            ))));
      allow update: if validFollowUp(request.resource.data) && (isAdmin()
        || (isCounselor()
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == resource.data.ownerUid
          && request.resource.data.assigneeUid == resource.data.assigneeUid
          && request.resource.data.studentId == resource.data.studentId)
        || (isStudent()
          && resource.data.assigneeUid == request.auth.uid
          && isValidStudentCompletion()));
      allow delete: if isAdmin()
        || (isCounselor()
          && resource.data.ownerUid == request.auth.uid
          && isAssignedStudent(resource.data.studentId));
    }

    match /counselorAvailability/{availabilityId} {
      allow read: if isAdmin()
        || isDocumentCounselor(resource.data.counselorUid)
        || (isStudent() && (resource.data.status == 'open' || resource.data.bookedByUid == request.auth.uid));
      allow create: if validCounselorAvailability(request.resource.data)
        && request.resource.data.status == 'open'
        && (isAdmin()
          || (isCounselor()
            && request.resource.data.counselorUid == request.auth.uid));
      allow update: if validCounselorAvailability(request.resource.data)
        && (isAdmin()
          || (isCounselor()
            && resource.data.counselorUid == request.auth.uid
            && request.resource.data.counselorUid == resource.data.counselorUid)
          || (isStudent()
            && request.resource.data.counselorUid == resource.data.counselorUid
            && request.resource.data.date == resource.data.date
            && request.resource.data.time == resource.data.time
            && request.resource.data.get('endTime', '') == resource.data.get('endTime', '')
            && request.resource.data.duration == resource.data.duration
            && request.resource.data.location == resource.data.location
            && ((resource.data.status == 'open'
              && request.resource.data.status == 'booked'
              && request.resource.data.bookedByUid == request.auth.uid
              && validText(request.resource.data.appointmentId, 128)
              && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['status', 'appointmentId', 'bookedByUid', 'holdReason', 'updatedAt'])
              && existsAfter(/databases/$(database)/documents/appointments/$(request.resource.data.appointmentId))
              && getAfter(/databases/$(database)/documents/appointments/$(request.resource.data.appointmentId)).data.studentUid == request.auth.uid)
            || (resource.data.bookedByUid == request.auth.uid
              && request.resource.data.status in ['open', 'booked', 'closed']
              && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['status', 'appointmentId', 'bookedByUid', 'holdReason', 'closedReason', 'reopenDecision', 'updatedAt'])))));
      allow delete: if isAdmin()
        || (isCounselor() && resource.data.counselorUid == request.auth.uid);
    }

    match /appointments/{appointmentId} {
      allow read: if isAdmin()
        || isDocumentCounselor(resource.data.counselorUid)
        || (isStudent() && resource.data.studentUid == request.auth.uid);
      allow create: if validAppointment(request.resource.data) && (isAdmin()
        || (isCounselor()
          && request.resource.data.counselorUid == request.auth.uid
          && isAssignedStudent(request.resource.data.studentId)
          && hasMatchingStudentUid(
            request.resource.data.studentId,
            request.resource.data.studentUid
          ))
        || (isStudent()
          && request.resource.data.studentUid == request.auth.uid
          && request.resource.data.status == 'pending'
          && request.resource.data.requestedBy == 'student'
          && validText(request.resource.data.subject, 200)
          && validText(request.resource.data.requestMessage, 2000)
          && validText(request.resource.data.availabilityId, 128)
          && validText(request.resource.data.endTime, 5)
          && hasMatchingStudentUid(request.resource.data.studentId, request.resource.data.studentUid)
          && get(/databases/$(database)/documents/students/$(request.resource.data.studentId)).data.counselorUid == request.resource.data.counselorUid
          && exists(/databases/$(database)/documents/counselorAvailability/$(request.resource.data.availabilityId))
          && get(/databases/$(database)/documents/counselorAvailability/$(request.resource.data.availabilityId)).data.status == 'open'
          && get(/databases/$(database)/documents/counselorAvailability/$(request.resource.data.availabilityId)).data.counselorUid == request.resource.data.counselorUid
          && get(/databases/$(database)/documents/counselorAvailability/$(request.resource.data.availabilityId)).data.date == request.resource.data.date
          && get(/databases/$(database)/documents/counselorAvailability/$(request.resource.data.availabilityId)).data.time == request.resource.data.time
          && get(/databases/$(database)/documents/counselorAvailability/$(request.resource.data.availabilityId)).data.duration == request.resource.data.duration
          && (!('endTime' in get(/databases/$(database)/documents/counselorAvailability/$(request.resource.data.availabilityId)).data)
            || get(/databases/$(database)/documents/counselorAvailability/$(request.resource.data.availabilityId)).data.endTime == request.resource.data.endTime)
          && existsAfter(/databases/$(database)/documents/counselorAvailability/$(request.resource.data.availabilityId))
          && getAfter(/databases/$(database)/documents/counselorAvailability/$(request.resource.data.availabilityId)).data.status == 'booked'
          && getAfter(/databases/$(database)/documents/counselorAvailability/$(request.resource.data.availabilityId)).data.appointmentId == appointmentId
          && getAfter(/databases/$(database)/documents/counselorAvailability/$(request.resource.data.availabilityId)).data.bookedByUid == request.auth.uid));
      allow update: if validAppointment(request.resource.data) && (isAdmin()
        || (isCounselor()
          && resource.data.counselorUid == request.auth.uid
          && request.resource.data.counselorUid == resource.data.counselorUid
          && request.resource.data.studentUid == resource.data.studentUid
          && request.resource.data.studentId == resource.data.studentId)
        || (isStudent()
          && resource.data.studentUid == request.auth.uid
          && request.resource.data.studentUid == resource.data.studentUid
          && request.resource.data.studentId == resource.data.studentId
          && request.resource.data.counselorUid == resource.data.counselorUid
          && resource.data.status in ['pending', 'confirmed', 'scheduled']
          && ((request.resource.data.status == 'cancelled'
            && request.resource.data.cancelledBy == request.auth.uid
            && request.resource.data.cancelledByRole == 'student'
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'cancelledAt', 'cancelledBy', 'cancelledByRole', 'updatedAt']))
          || (request.resource.data.rescheduleRequest is map
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['rescheduleRequest', 'rescheduleHistory', 'availabilityId', 'date', 'time', 'endTime', 'duration', 'location', 'subject', 'requestMessage', 'status', 'cancelledAt', 'cancelledBy', 'updatedAt'])))));
      allow delete: if isAdmin()
        || (isDocumentCounselor(resource.data.counselorUid)
          && isAssignedStudent(resource.data.studentId));
    }

    match /programs/{programId} {
      allow read: if signedIn();
      allow create, update, delete: if isStaff();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
