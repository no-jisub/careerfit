{
  "name": "careerfit",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:firebase": "vite --mode emulator",
    "build": "vite build && node scripts/prepare-sites.mjs",
    "preview": "vite preview",
    "test": "node --test tests/*.test.js",
    "firebase:emulators": "firebase emulators:start --project careerfit-local",
    "firebase:seed": "node scripts/seed-emulator.mjs",
    "firebase:verify": "node scripts/verify-emulator-flow.mjs",
    "firebase:deploy:hosting": "npm run build && firebase deploy --only hosting",
    "firebase:deploy:functions": "firebase deploy --only functions",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes",
    "firebase:deploy:backend-config": "firebase deploy --only auth,firestore:rules,firestore:indexes,functions"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "firebase": "12.16.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "vite": "8.1.5"
  },
  "devDependencies": {
    "firebase-admin": "^14.2.0",
    "firebase-tools": "15.24.0"
  }
}
